# expendit local development. Copy to .env: cp .env.example .env

# ── api/common (Go) ──
JWT_SECRET=dev-secret-change-me
FRONTEND_URL=http://localhost:3000

# ── Optional integrations (features degrade gracefully if unset) ──
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
GROQ_API_KEY=
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_PORT=587

# MongoDB and Redis are provided by docker-compose (hosts: mongo, redis).
