# expendit local development. Copy to .env: cp .env.example .env
JWT_SECRET=dev-secret-change-me
FRONTEND_URL=http://localhost:3000

# Web (browser-exposed, inlined at build time)
NEXT_PUBLIC_BASE_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional integrations (features degrade gracefully if unset)
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
GROQ_API_KEY=
EMAIL_FROM=noreply@example.com
SMTP_Host=
SMTP_User=
SMTP_Password=
SMTP_Port=587

# MongoDB and Redis are provided by docker-compose (hosts: mongo, redis).
