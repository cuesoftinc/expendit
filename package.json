{
  "devDependencies": {
    "husky": "^9.0.10",
    "lint-staged": "^15.0.0",
    "npm-run-all": "^4.1.5",
    "prepush-if-changed": "^1.0.8"
  },
  "name": "expendit",
  "description": "## About",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky install || true",
    "lint": "lint-staged",
    "pre-push": "npm-run-all pre-push:app pre-push:home",
    "pre-push:app": "cd web/app && npm run pre-push",
    "pre-push:home": "cd web/home && npm run pre-push"
  },
  "lint-staged": {
    "web/app/src/**/*.{js,jsx,ts,tsx}": "eslint --cache --fix",
    "web/home/src/**/*.{js,jsx,ts,tsx,css,scss,html,md}": "prettier --write"
  },
